{
  "name": "rardar",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev --hostname 127.0.0.1",
    "data:collect": "python -m pipeline.collect_github --out data/snapshots/latest.json",
    "data:build": "python -m pipeline.rebuild_derived --data-dir data",
    "data:derive": "python -m pipeline.rebuild_derived --data-dir data",
    "data:refresh": "python -m pipeline.refresh --data-dir data --limit 30 --analyze-top 5",
    "data:signals": "python -m pipeline.collect_signals --out data/signals/latest.json --window-hours 48 --limit 30",
    "data:queue": "python -m pipeline.codex_queue",
    "data:generation:status": "python -m pipeline.generations --data-dir data status",
    "data:generation:bootstrap": "python -m pipeline.generations --data-dir data bootstrap",
    "data:generation:publish": "python -m pipeline.generations --data-dir data publish",
    "data:generation:rollback": "python -m pipeline.generations --data-dir data rollback",
    "data:audit": "python -m pipeline.audit_data --data-dir data",
    "data:validate": "python -m pipeline.schema_validation --data-dir data",
    "data:ingest": "python -m pipeline.ingest_enrichment",
    "data:identity:migrate": "python -m pipeline.migrate_project_identity --data-dir data",
    "data:schedule": "python -m pipeline.scheduler --data-dir data --at 08:00 --timezone Asia/Shanghai --analyze-top 5 --status-path %LOCALAPPDATA%/Rardar/runtime/scheduler-status.json --skip-initial",
    "local:start": "python -m pipeline.runtime start",
    "local:stop": "python -m pipeline.runtime stop",
    "local:status": "python -m pipeline.runtime status",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run build && npm run test:node",
    "test:node": "node --test --test-concurrency=1 tests/action-events.test.mjs tests/project-identity.test.mjs tests/scoring-semantics.test.mjs tests/rendered-html.test.mjs tests/vinext-http.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "security:audit:prod": "npm audit --omit=dev --registry=https://registry.npmjs.org",
    "verify": "node scripts/verify.mjs",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "miniflare": "4.20260617.0",
    "postcss": "8.5.14",
    "undici": "7.28.0",
    "wrangler": "4.102.0",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.41.0",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.102.0"
  },
  "type": "module"
}
