{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rardar.local/contracts/github-snapshot.schema.json",
  "title": "Rardar GitHub snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "captured_at",
    "queries",
    "count",
    "repositories"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "captured_at": { "type": "string", "format": "date-time" },
    "queries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
    },
    "query_status": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/queryStatus" }
    },
    "successful_query_count": { "type": "integer", "minimum": 0 },
    "failed_query_count": { "type": "integer", "minimum": 0 },
    "count": { "type": "integer", "minimum": 0 },
    "repositories": {
      "type": "array",
      "maxItems": 5000,
      "items": { "$ref": "#/$defs/repository" }
    }
  },
  "dependentRequired": {
    "query_status": ["successful_query_count", "failed_query_count"],
    "successful_query_count": ["query_status", "failed_query_count"],
    "failed_query_count": ["query_status", "successful_query_count"]
  },
  "$defs": {
    "repositoryName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "format": "repository",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "httpUrl": {
      "type": "string",
      "minLength": 8,
      "maxLength": 2048,
      "format": "http-url",
      "pattern": "^https?://[^\\s]+$"
    },
    "queryStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query", "state", "item_count", "error"],
      "properties": {
        "query": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "state": { "enum": ["healthy", "failed"] },
        "item_count": { "type": "integer", "minimum": 0 },
        "error": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1, "maxLength": 300 }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "healthy" } } },
          "then": { "properties": { "error": { "type": "null" } } }
        },
        {
          "if": { "properties": { "state": { "const": "failed" } } },
          "then": {
            "properties": {
              "error": { "type": "string", "minLength": 1, "maxLength": 300 }
            }
          }
        }
      ]
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "url",
        "description",
        "owner",
        "language",
        "license",
        "topics",
        "stars",
        "forks",
        "open_issues",
        "created_at",
        "updated_at",
        "pushed_at",
        "default_branch",
        "captured_at",
        "candidate_query",
        "analysis_state"
      ],
      "properties": {
        "repo": { "$ref": "#/$defs/repositoryName" },
        "url": { "$ref": "#/$defs/httpUrl" },
        "description": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "maxLength": 4000 }
          ]
        },
        "owner": { "type": "string", "minLength": 1, "maxLength": 100 },
        "language": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1, "maxLength": 100 }
          ]
        },
        "license": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1, "maxLength": 100 }
          ]
        },
        "topics": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        },
        "stars": { "type": "integer", "minimum": 0 },
        "forks": { "type": "integer", "minimum": 0 },
        "open_issues": { "type": "integer", "minimum": 0 },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "pushed_at": { "type": "string", "format": "date-time" },
        "default_branch": { "type": "string", "minLength": 1, "maxLength": 255 },
        "captured_at": { "type": "string", "format": "date-time" },
        "candidate_query": { "type": "string", "minLength": 1, "maxLength": 5000 },
        "analysis_state": { "enum": ["pending"] }
      }
    }
  }
}
