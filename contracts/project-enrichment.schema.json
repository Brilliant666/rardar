{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rardar.local/contracts/project-enrichment.schema.json",
  "title": "Rardar project enrichment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "repository",
    "analyzedAt",
    "titleZh",
    "summaryZh",
    "category",
    "capabilities",
    "taskTerms",
    "bestFor",
    "reusePlan",
    "limitation",
    "evidenceSummary",
    "sourceUrl"
  ],
  "properties": {
    "schemaVersion": { "enum": [0, 1] },
    "repository": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "format": "repository",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "sourcePushedAt": { "type": "string", "format": "date-time" },
    "sourceAnalysisAt": { "type": "string", "format": "date-time" },
    "analyzedAt": { "type": "string", "format": "date-time" },
    "model": { "type": "string", "minLength": 1, "maxLength": 200 },
    "titleZh": { "type": "string", "minLength": 1, "maxLength": 500 },
    "summaryZh": { "type": "string", "minLength": 1, "maxLength": 5000 },
    "category": { "type": "string", "minLength": 1, "maxLength": 200 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 300 }
    },
    "taskTerms": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 200 }
    },
    "bestFor": { "type": "string", "minLength": 1, "maxLength": 5000 },
    "reusePlan": { "type": "string", "minLength": 1, "maxLength": 8000 },
    "limitation": { "type": "string", "minLength": 1, "maxLength": 8000 },
    "evidenceSummary": { "type": "string", "minLength": 1, "maxLength": 10000 },
    "sourceUrl": {
      "type": "string",
      "minLength": 8,
      "maxLength": 2048,
      "format": "http-url",
      "pattern": "^https?://[^\\s]+$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "schemaVersion": { "const": 1 } },
        "required": ["schemaVersion"]
      },
      "then": { "required": ["sourcePushedAt", "sourceAnalysisAt"] }
    },
    {
      "if": {
        "properties": { "schemaVersion": { "const": 0 } },
        "required": ["schemaVersion"]
      },
      "then": {
        "not": {
          "anyOf": [
            { "required": ["sourcePushedAt"] },
            { "required": ["sourceAnalysisAt"] }
          ]
        }
      }
    }
  ]
}
